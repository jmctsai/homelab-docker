# -------------------------
# CIFS CONFIG
# -------------------------
CIFS_SERVER=192.168.1.249

# Format: "share:mountpoint"
CIFS_MOUNTS=(
    "media:/media"
    "docker:/docker"
)

# Credentials stored directly in .env
CIFS_USERNAME="username"
CIFS_PASSWORD="password"

# CIFS mount options (Synology‑compatible)
CIFS_OPTIONS="vers=3.1.1,uid=1000,gid=1000,file_mode=0775,dir_mode=0775,_netdev"
