# Ignore everything by default
*

# Allow directories so Git can descend into them
!*/

# -------------------------
# Track all docker-compose files
# -------------------------
!**/compose.yaml

# Track env templates (but not real secrets)
!**/.env.template

# -------------------------
# Track scripts
# -------------------------
!scripts/**
!scripts/**/*.sh
!scripts/**/*.template

# -------------------------
# Ignore real env files
# -------------------------
.env
**/.env
**/*.env
.gitconfig

# -------------------------
# Ignore logs everywhere
# -------------------------
*.log
**/*.log
**/logs/

# -------------------------
# Ignore Docker runtime data
# -------------------------
**/config/
**/data/
**/downloads/
**/cache/
**/tmp/
**/state/
**/db/
**/media/
**/gluetun-data/
**/volumes/

# Ignore hidden/disabled service folders
.*/

# Ignore OS/editor junk
.DS_Store
Thumbs.db
*.swp
*.swo
