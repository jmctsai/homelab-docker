# Ignore everything by default
*

# Allow directories so Git can descend into them
!*/

# -------------------------
# Track all docker-compose files
# -------------------------
!**/compose.yaml

# Track env templates (but not real secrets)
!**/.env.template

# -------------------------
# Track scripts
# -------------------------
!scripts/**
!scripts/**/*.sh
!scripts/**/*.template

# -------------------------
# Ignore real env files everywhere
# -------------------------
.env
**/.env
**/*.env
.gitconfig

# -------------------------
# Ignore logs everywhere
# -------------------------
*.log
**/*.log
**/logs/

# -------------------------
# Ignore hidden folders at repo root ONLY
# (like .git, .github, .vscode)
# -------------------------
./.*

# -------------------------
# Allow hidden service folders to be tracked
# -------------------------
!services/.*/
!services/.*/**

# -------------------------
# Ignore OS/editor junk
# -------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
